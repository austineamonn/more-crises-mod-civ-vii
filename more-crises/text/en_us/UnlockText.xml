<?xml version="1.0" encoding="utf-8"?>
<Database>
	<EnglishText>
		<!-- Famine Crisis -->
		<Row Tag="LOC_UNLOCK_FAMINE_FISHERIES_NAME">
			<Text>Fisheries</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_FAMINE_FISHERIES_DESCRIPTION">
			<Text>Have 5 Fishing Quays.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_FAMINE_FISHERIES_TOOLTIP">
			<Text>Your Civilization kept it's people fed by fishing on the coast.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_EXP_FAMINE_FISHERIES_DESCRIPTION">
			<Text>Unlock [icon:RADIAL_TECH] Cartography. [B]+50% [icon:YIELD_PRODUCTION][/B] towards constructing Wharfs.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_FAMINE_STARVING_WORKERS_NAME">
			<Text>Starving Workers</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_FAMINE_STARVING_WORKERS_DESCRIPTION">
			<Text>Have [B]6 [icon:SPECIALIST] [TIP:LOC_PEDIA_CONCEPTS_SPECIALIST_TOOLTIP]Specialists[/TIP][/B].</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_FAMINE_STARVING_WORKERS_TOOLTIP">
			<Text>Many Artists and Scientists died from starvation, now our Civilization will treat them better.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_EXP_FAMINE_STARVING_WORKERS_DESCRIPTION">
			<Text>+25% [icon:YIELD_FOOD] and [icon:YIELD_HAPPINESS] towards [TIP:LOC_PEDIA_CONCEPTS_MAINTENANCE_TOOLTIP]maintaining[/TIP] [icon:SPECIALIST] [TIP:LOC_PEDIA_CONCEPTS_SPECIALIST_TOOLTIP]Specialists[/TIP].</Text>
		</Row>
		<!-- Succession Crisis -->
		<Row Tag="LOC_UNLOCK_SUCCESSION_ENTENTE_NAME">
			<Text>Entente</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_SUCCESSION_ENTENTE_DESCRIPTION">
			<Text>Have 2 [icon:PLAYER_RELATIONSHIP_ALLIANCE]  [TIP:LOC_PEDIA_CONCEPTS_ALLIANCE_TOOLTIP]Alliances[/TIP].</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_SUCCESSION_ENTENTE_TOOLTIP">
			<Text>Our alliances held steady when an heir could not be found.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_EXP_SUCCESSION_ENTENTE_DESCRIPTION">
			<Text>[B]+5 [icon:YIELD_DIPLOMACY][/B] for every [icon:PLAYER_RELATIONSHIP_ALLIANCE]  [TIP:LOC_PEDIA_CONCEPTS_ALLIANCE_TOOLTIP]Alliance[/TIP] you have.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_SUCCESSION_BELLIGERENT_NAME">
			<Text>Belligerent</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_SUCCESSION_BELLIGERENT_DESCRIPTION">
			<Text>Declare a [icon:WAR] War.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_SUCCESSION_BELLIGERENT_TOOLTIP">
			<Text>When our civilization was vulnerable we learned that offense is better than defense.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_EXP_SUCCESSION_BELLIGERENT_DESCRIPTION">
			<Text>[B]+2 [icon:WAR_SUPPORT] [TIP:LOC_PEDIA_CONCEPTS_WAR_SUPPORT_TOOLTIP]War Support[/TIP][/B] on [icon:WAR] Wars you declare.</Text>
		</Row>
		<!-- Inflation Crisis -->
		<Row Tag="LOC_UNLOCK_INFLATION_INVESTOR_WEALTH_NAME">
			<Text>Investor Wealth</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_INFLATION_INVESTOR_WEALTH_DESCRIPTION">
			<Text>End the Age with Positive Gold.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_INFLATION_INVESTOR_WEALTH_TOOLTIP">
			<Text>Though our Government ran low on money, private investors remained wealthy.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_MOD_INFLATION_INVESTOR_WEALTH_DESCRIPTION">
			<Text>[B]+3 [icon:YIELD_GOLD][/B] on Gold [TIP:LOC_PEDIA_CONCEPTS_BUILDINGS_TOOLTIP]Buildings[/TIP].</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_INFLATION_ENDLESS_TRADE_NAME">
			<Text>Endless Trade</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_INFLATION_ENDLESS_TRADE_DESCRIPTION">
			<Text>Have 10 [icon:TRADE_ROUTE] [TIP:LOC_PEDIA_CONCEPTS_TRADE_ROUTE_TOOLTIP]Trade Routes[/TIP].</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_INFLATION_ENDLESS_TRADE_TOOLTIP">
			<Text>Our Civilization traded so far and wide that no price increases could slow our growth.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_MOD_INFLATION_ENDLESS_TRADE_DESCRIPTION">
			<Text>[B]+1 [icon:TRADE_ROUTE] [TIP:LOC_PEDIA_CONCEPTS_TRADE_ROUTE_TOOLTIP]Trade Route Capacity[/TIP][/B] with all Leaders.</Text>
		</Row>
		<!-- Isolationism Crisis -->
		<Row Tag="LOC_UNLOCK_ISOLATIONISM_SELF_RELIANCE_NAME">
			<Text>Self Reliance</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_ISOLATIONISM_SELF_RELIANCE_DESCRIPTION">
			<Text>Have 3 [icon:YIELD_TOWNS] [TIP:LOC_PEDIA_CONCEPTS_TOWN_TOOLTIP]Towns[/TIP] with the [icon:PROJECT_TOWN_INTERNAL_TRADE] Internal Trade Town Specialization.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_ISOLATIONISM_SELF_RELIANCE_TOOLTIP">
			<Text>When other empires closed their borders, our Civilzation found economic prosperity internally.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_MOD_ISOLATIONISM_SELF_RELIANCE_DESCRIPTION">
			<Text>[B]+75% [icon:YIELD_GOLD][/B] toward purchasing Factories.[B]-1 [icon:TRADE_ROUTE] [TIP:LOC_PEDIA_CONCEPTS_TRADE_ROUTE_TOOLTIP]Trade Route Capacity[/TIP][/B] with all Leaders.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_ISOLATIONISM_RUINOPHILIA_NAME">
			<Text>Ruinophilia</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_ISOLATIONISM_RUINOPHILIA_DESCRIPTION">
			<Text>Have 20 displayed Great Works.</Text>
		</Row>
		<Row Tag="LOC_UNLOCK_ISOLATIONISM_RUINOPHILIA_TOOLTIP">
			<Text>Our Civilization looked to the past to protect our unique culture for the future.</Text>
		</Row>
		<Row Tag="LOC_CARD_AT_MOD_ISOLATIONISM_RUINOPHILIA_DESCRIPTION">
			<Text>Unlock [icon:RADIAL_CIVICS] Natural History. [B]+2 [icon:YIELD_CULTURE][/B] on displayed Great Works.</Text>
		</Row>
	</EnglishText>
</Database>