<?xml version="1.0" encoding="utf-8"?>
<Database>
	<EnglishText>
		<!-- Famine Crisis Policies -->
		<Row Tag="LOC_TRADITION_EMPTY_STORAGE_NAME">
			<Text>Empty Storage</Text>
		</Row>
		<Row Tag="LOC_TRADITION_EMPTY_STORAGE_DESCRIPTION">
			<Text>-5 [icon:YIELD_GOLD] on [icon:YIELD_WAREHOUSE] [TIP:LOC_PEDIA_CONCEPTS_WAREHOUSE_TOOLTIP]Warehouse[/TIP] [TIP:LOC_PEDIA_CONCEPTS_BUILDINGS_TOOLTIP]Buildings[/TIP] in [icon:YIELD_TOWNS] [TIP:LOC_PEDIA_CONCEPTS_TOWN_TOOLTIP]Towns[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_CITY_SLUM_NAME">
			<Text>City Slum</Text>
		</Row>
		<Row Tag="LOC_TRADITION_CITY_SLUM_DESCRIPTION">
			<Text>-5 [icon:YIELD_GOLD] on Food [TIP:LOC_PEDIA_CONCEPTS_BUILDINGS_TOOLTIP]Buildings[/TIP] in [icon:YIELD_CITIES] [TIP:LOC_PEDIA_CONCEPTS_CITIES_TOOLTIP]Cities[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_FOOD_INSECURITY_NAME">
			<Text>Food Insecurity</Text>
		</Row>
		<Row Tag="LOC_TRADITION_FOOD_INSECURITY_DESCRIPTION">
			<Text>-5 [icon:YIELD_FOOD] on [icon:CITY_URBAN] [TIP:LOC_PEDIA_CONCEPTS_DISTRICT_TOOLTIP]Districts[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_CITY_MIGRATION_NAME">
			<Text>City Migration</Text>
		</Row>
		<Row Tag="LOC_TRADITION_CITY_MIGRATION_DESCRIPTION">
			<Text>-50% [icon:GROWTH_RATE] [TIP:LOC_PEDIA_CONCEPTS_GROWTH_RATE_TOOLTIP]Growth Rate[/TIP]in [icon:YIELD_CITIES] [TIP:LOC_PEDIA_CONCEPTS_CITIES_TOOLTIP]Cities[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_OVERWORKED_FARMERS_NAME">
			<Text>Overworked Farmers</Text>
		</Row>
		<Row Tag="LOC_TRADITION_OVERWORKED_FARMERS_DESCRIPTION">
			<Text>-75%[icon:YIELD_PRODUCTION] and [icon:YIELD_FOOD] in [icon:YIELD_TOWNS] [TIP:LOC_PEDIA_CONCEPTS_TOWN_TOOLTIP]Towns[/TIP] with a [icon:PROJECT_GROWTH] Growing Focus.</Text>
		</Row>
		<Row Tag="LOC_TRADITION_KNOWLEDGE_LOSS_NAME">
			<Text>Knowledge Loss</Text>
		</Row>
		<Row Tag="LOC_TRADITION_KNOWLEDGE_LOSS_DESCRIPTION">
			<Text>-2 [icon:YIELD_SCIENCE] from [icon:SPECIALIST] [TIP:LOC_PEDIA_CONCEPTS_SPECIALIST_TOOLTIP]Specialists[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_DEATH_OF_THE_ARTISTS_NAME">
			<Text>Death of the Artists</Text>
		</Row>
		<Row Tag="LOC_TRADITION_DEATH_OF_THE_ARTISTS_DESCRIPTION">
			<Text>-2 [icon:YIELD_CULTURE] from [icon:SPECIALIST] [TIP:LOC_PEDIA_CONCEPTS_SPECIALIST_TOOLTIP]Specialists[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_RESOURCE_SCARCITY_NAME">
			<Text>Resource Scarcity</Text>
		</Row>
		<Row Tag="LOC_TRADITION_RESOURCE_SCARCITY_DESCRIPTION">
			<Text>-1 [icon:YIELD_GOLD] and -2 [icon:YIELD_FOOD] on [icon:RADIAL_RESOURCES] [TIP:LOC_PEDIA_CONCEPTS_RESOURCES_TOOLTIP]Resource[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_UNDERRESOURCED_COMMUNITIES_NAME">
			<Text>Underserved Communities</Text>
		</Row>
		<Row Tag="LOC_TRADITION_UNDERRESOURCED_COMMUNITIES_DESCRIPTION">
			<Text>-6 [icon:YIELD_FOOD] in [TIP:LOC_PEDIA_CONCEPTS_SETTLEMENT_TOOLTIP]Settlements[/TIP] with unfilled [icon:RADIAL_RESOURCES] [TIP:LOC_PEDIA_CONCEPTS_RESOURCE_CAPACITY_TOOLTIP]Resource Capacity[/TIP].</Text>
		</Row>
		<!-- Succession Crisis Policies -->
		<Row Tag="LOC_TRADITION_COVER_UP_NAME">
			<Text>Cover Up</Text>
		</Row>
		<Row Tag="LOC_TRADITION_COVER_UP_DESCRIPTION">
			<Text>-1 [icon:YIELD_DIPLOMACY] on displayed [icon:GREATWORK] [TIP:LOC_PEDIA_CONCEPTS_GREAT_WORKS_TOOLTIP]Great Works[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_PRIMOGENITURE_NAME">
			<Text>Primogeniture</Text>
		</Row>
		<Row Tag="LOC_TRADITION_PRIMOGENITURE_DESCRIPTION">
			<Text>-2 [icon:YIELD_DIPLOMACY] on Monuments.</Text>
		</Row>
		<Row Tag="LOC_TRADITION_ULTIMOGENITURE_NAME">
			<Text>Ultimogeniture</Text>
		</Row>
		<Row Tag="LOC_TRADITION_ULTIMOGENITURE_DESCRIPTION">
			<Text>-2 [icon:YIELD_DIPLOMACY] on Barracks.</Text>
		</Row>
		<Row Tag="LOC_TRADITION_FRATRICIDE_NAME">
			<Text>Fratricide</Text>
		</Row>
		<Row Tag="LOC_TRADITION_FRATRICIDE_DESCRIPTION">
			<Text>+1 [icon:WAR_SUPPORT] [TIP:LOC_PEDIA_CONCEPTS_WAR_SUPPORT_TOOLTIP]War Support[/TIP] on [icon:WAR] Wars you declare. -3 [icon:YIELD_DIPLOMACY] in [icon:YIELD_CITIES] [TIP:LOC_PEDIA_CONCEPTS_CITIES_TOOLTIP]Cities[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_DEFENSIVE_PACT_NAME">
			<Text>Defensive Pact</Text>
		</Row>
		<Row Tag="LOC_TRADITION_DEFENSIVE_PACT_DESCRIPTION">
			<Text>+2 [icon:WAR_SUPPORT] [TIP:LOC_PEDIA_CONCEPTS_WAR_SUPPORT_TOOLTIP]War Support[/TIP] on [icon:WAR] Wars declared against you. -3 [icon:YIELD_DIPLOMACY] on Diplomacy [TIP:LOC_PEDIA_CONCEPTS_BUILDINGS_TOOLTIP]Buildings[/TIP].</Text>
		</Row>
		<Row Tag="LOC_TRADITION_RIVAL_HEIRS_NAME">
			<Text>Rival Heirs</Text>
		</Row>
		<Row Tag="LOC_TRADITION_RIVAL_HEIRS_DESCRIPTION">
			<Text>+1 [icon:YIELD_DIPLOMACY] for every [icon:UNIT_ARMY_COMMANDER] Commander XP earned. -5 [icon:YIELD_DIPLOMACY] for every [icon:UNIT_ARMY_COMMANDER] Commander.</Text>
		</Row>
		<Row Tag="LOC_TRADITION_BORDER_TENSIONS_NAME">
			<Text>Border Tensions</Text>
		</Row>
		<Row Tag="LOC_TRADITION_BORDER_TENSIONS_DESCRIPTION">
			<Text>-5 [icon:YIELD_DIPLOMACY] for every leader you are [icon:PLAYER_RELATIONSHIP_UNFRIENDLY] Unfriendly or [icon:PLAYER_RELATIONSHIP_HOSTILE] Hostile with.</Text>
		</Row>
		<Row Tag="LOC_TRADITION_BUMBLING_LEADERSHIP_NAME">
			<Text>Bumbling Leadership</Text>
		</Row>
		<Row Tag="LOC_TRADITION_BUMBLING_LEADERSHIP_DESCRIPTION">
			<Text>-5 [icon:YIELD_DIPLOMACY] for every leader you are [icon:PLAYER_RELATIONSHIP_FRIENDLY] Friendly or [icon:PLAYER_RELATIONSHIP_HELPFUL] Helpful with.</Text>
		</Row>
	</EnglishText>
</Database>